ENVIRONMENT=local

# --------------------------------------------------
# Application Metadata
# --------------------------------------------------

APP_NAME=Cortex
APP_VERSION=0.1.0

# --------------------------------------------------
# Runtime Environment
# --------------------------------------------------

DEBUG=true
LOG_LEVEL=DEBUG

# --------------------------------------------------
# AI Configuration
# --------------------------------------------------

AI_PROVIDER=mock

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --------------------------------------------------
# Embedding Configuration
# --------------------------------------------------

EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=nomic-embed-text